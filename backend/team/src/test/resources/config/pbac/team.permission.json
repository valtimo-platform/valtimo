{
    "changesetId": "team-v1",
    "permissions": [
        {
            "resourceType": "com.ritense.team.domain.Team",
            "actions": [
                "view",
                "view_list",
                "create",
                "modify",
                "delete",
                "assign",
                "assignable"
            ],
            "roleKey": "ROLE_ADMIN"
        },
        {
            "resourceType": "com.ritense.team.domain.Team",
            "actions": [
                "assignable"
            ],
            "roleKey": "ROLE_USER"
        },
        {
            "resourceType": "com.ritense.team.domain.Team",
            "actions": [
                "view",
                "view_list",
                "modify",
                "delete",
                "assign"
            ],
            "roleKey": "ROLE_USER",
            "conditions": [
                {
                    "type": "field",
                    "field": "users",
                    "operator": "list_contains",
                    "value": "${currentUsername}"
                }
            ]
        }
    ]
}