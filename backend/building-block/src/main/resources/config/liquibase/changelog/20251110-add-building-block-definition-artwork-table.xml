<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <createTable tableName="building_block_definition_artwork">
            <column name="building_block_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>

            <!-- Base64-encoded PNG image -->
            <column name="image_base64" type="TEXT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="building_block_definition_artwork"
            columnNames="building_block_definition_key, building_block_definition_version_tag"
            constraintName="pk_building_block_definition_artwork"/>

        <addForeignKeyConstraint
            baseTableName="building_block_definition_artwork"
            baseColumnNames="building_block_definition_key, building_block_definition_version_tag"
            constraintName="fk_bb_def_artwork_bb_def"
            referencedTableName="building_block_definition"
            referencedColumnNames="building_block_definition_key, building_block_definition_version_tag"
            onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>