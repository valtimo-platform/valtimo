<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet author="Ritense" id="1">
        <addColumn tableName="building_block_instance">
            <column name="parent_building_block_instance_id" type="${uuidType}">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="building_block_instance"
                baseColumnNames="parent_building_block_instance_id"
                referencedTableName="building_block_instance"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_bbinst_parent_bbinst"/>

        <createIndex indexName="idx_bbinst_parent" tableName="building_block_instance">
            <column name="parent_building_block_instance_id"/>
        </createIndex>

        <createIndex indexName="idx_bbinst_case_document" tableName="building_block_instance">
            <column name="case_document_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
