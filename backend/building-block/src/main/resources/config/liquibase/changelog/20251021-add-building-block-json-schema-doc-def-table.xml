<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="building-block-json-schema-def-1" author="Ritense">
        <createTable tableName="building_block_json_schema_document_definition">
            <column name="document_definition_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="json_schema" type="JSON">
                <constraints nullable="false"/>
            </column>

            <column name="created_on" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="building_block_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="building_block_json_schema_document_definition"
            columnNames="document_definition_name, building_block_definition_key, building_block_definition_version_tag"
            constraintName="pk_bb_json_schema_doc_def"/>

        <addForeignKeyConstraint
            baseTableName="building_block_json_schema_document_definition"
            baseColumnNames="building_block_definition_key, building_block_definition_version_tag"
            referencedTableName="building_block_definition"
            referencedColumnNames="building_block_definition_key, building_block_definition_version_tag"
            onDelete="CASCADE"
            constraintName="fk_bb_json_schema_to_bb_definition"/>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <dropAllForeignKeyConstraints baseTableName="building_block_json_schema_document_definition"/>
        <dropTable tableName="building_block_json_schema_document_definition"/>
    </changeSet>
</databaseChangeLog>