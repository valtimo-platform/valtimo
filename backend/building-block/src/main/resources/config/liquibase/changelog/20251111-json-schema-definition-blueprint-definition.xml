<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <addColumn tableName="json_schema_document_definition">
            <column name="blueprint_type" type="VARCHAR(40)"/>
            <column name="blueprint_key" type="VARCHAR(256)"/>
            <column name="blueprint_version_tag" type="VARCHAR(200)"/>
        </addColumn>
        <sql>
            update json_schema_document_definition
            set blueprint_type = 'CASE',
                blueprint_key = case_definition_key,
                blueprint_version_tag = case_definition_version_tag
        </sql>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="blueprint_type" columnDataType="VARCHAR(40)"/>
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="blueprint_key" columnDataType="VARCHAR(256)"/>
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="blueprint_version_tag" columnDataType="VARCHAR(200)"/>
        <dropPrimaryKey tableName="json_schema_document_definition" constraintName="json_schema_document_definition_pkey" />
        <dropColumn tableName="json_schema_document_definition" columnName="case_definition_key"/>
        <dropColumn tableName="json_schema_document_definition" columnName="case_definition_version_tag"/>
        <addPrimaryKey tableName="json_schema_document_definition" constraintName="json_schema_document_definition_pkey"
                       columnNames="document_definition_name, blueprint_type, blueprint_key, blueprint_version_tag"/>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <addColumn tableName="json_schema_document">
            <column name="blueprint_type" type="VARCHAR(40)"/>
            <column name="blueprint_key" type="VARCHAR(256)"/>
            <column name="blueprint_version_tag" type="VARCHAR(200)"/>
        </addColumn>
        <sql>
            update json_schema_document
            set blueprint_type = 'CASE',
                blueprint_key = case_definition_key,
                blueprint_version_tag = case_definition_version_tag
        </sql>
        <addNotNullConstraint tableName="json_schema_document" columnName="blueprint_type" columnDataType="VARCHAR(40)"/>
        <addNotNullConstraint tableName="json_schema_document" columnName="blueprint_key" columnDataType="VARCHAR(256)"/>
        <addNotNullConstraint tableName="json_schema_document" columnName="blueprint_version_tag" columnDataType="VARCHAR(200)"/>
        <dropColumn tableName="json_schema_document" columnName="case_definition_key"/>
        <dropColumn tableName="json_schema_document" columnName="case_definition_version_tag"/>
        <addForeignKeyConstraint constraintName="fk_json_document_definition_blueprint"
                                 baseTableName="json_schema_document"
                                 baseColumnNames="document_definition_name, blueprint_type, blueprint_key, blueprint_version_tag"
                                 referencedTableName="json_schema_document_definition"
                                 referencedColumnNames="document_definition_name, blueprint_type, blueprint_key, blueprint_version_tag"/>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <addColumn tableName="json_schema_document_snapshot">
            <column name="blueprint_type" type="VARCHAR(40)"/>
        </addColumn>
        <renameColumn tableName="json_schema_document_snapshot" oldColumnName="case_definition_key"
                      newColumnName="blueprint_key"/>
        <renameColumn tableName="json_schema_document_snapshot" oldColumnName="case_definition_version_tag"
                      newColumnName="blueprint_version_tag"/>
    </changeSet>
</databaseChangeLog>
