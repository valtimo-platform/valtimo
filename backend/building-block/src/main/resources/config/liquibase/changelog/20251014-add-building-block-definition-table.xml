<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <createTable tableName="building_block_definition">
            <column name="building_block_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="CLOB"/>

            <column name="created_by" type="VARCHAR(255)"/>
            <column name="created_date" type="TIMESTAMP"/>

            <column name="based_on_version_tag" type="VARCHAR(200)"/>

            <column name="is_final" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="building_block_definition"
            columnNames="building_block_definition_key, building_block_definition_version_tag"
            constraintName="pk_building_block_definition"/>
    </changeSet>
</databaseChangeLog>