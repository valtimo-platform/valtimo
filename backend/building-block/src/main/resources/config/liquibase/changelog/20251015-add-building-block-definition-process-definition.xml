<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet author="Ritense" id="building-block-def-process-def-link-1">
        <createTable tableName="process_definition_building_block_definition">
            <column name="process_definition_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="main" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="process_definition_building_block_definition"
            columnNames="process_definition_id, building_block_definition_key, building_block_definition_version_tag"
            constraintName="pk_procdef_bbdef"/>

        <addForeignKeyConstraint
            baseTableName="process_definition_building_block_definition"
            baseColumnNames="building_block_definition_key, building_block_definition_version_tag"
            referencedTableName="building_block_definition"
            referencedColumnNames="building_block_definition_key, building_block_definition_version_tag"
            onDelete="CASCADE"
            constraintName="fk_procdef_bbdef_to_bbdef"/>

        <createIndex indexName="idx_procdef_bbdef_proc" tableName="process_definition_building_block_definition">
            <column name="process_definition_id"/>
        </createIndex>

        <createIndex indexName="idx_procdef_bbdef_bb" tableName="process_definition_building_block_definition">
            <column name="building_block_definition_key"/>
            <column name="building_block_definition_version_tag"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>