<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd"
    logicalFilePath="config/liquibase/changelog/20260630-create-reindex-run-table.xml">

    <changeSet author="Ritense" id="create_table_document_opensearch_reindex_run">
        <createTable tableName="document_opensearch_reindex_run">
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="instance_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="scope" type="CLOB"/>
            <column name="page_size" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="last_id" type="${uuidType}"/>
            <column name="processed_count" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="skipped_count" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="started_on" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="heartbeat_on" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="finished_on" type="DATETIME"/>
            <column name="error" type="CLOB"/>
        </createTable>
        <createIndex tableName="document_opensearch_reindex_run" indexName="idx_reindex_run_status_started">
            <column name="status"/>
            <column name="started_on"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
