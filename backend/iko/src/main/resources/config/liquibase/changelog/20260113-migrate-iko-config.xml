<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet author="Ritense" id="1">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
            <tableExists tableName="plugin_configuration"/>
            <tableExists tableName="iko_repository_config"/>
        </preConditions>

        <sql>
            UPDATE iko_repository_config
            SET properties = jsonb_build_object('ikoServerUrl', (SELECT properties::jsonb->>'url' FROM plugin_configuration WHERE plugin_definition_key = 'iko' LIMIT 1))
            WHERE EXISTS (SELECT 1 FROM plugin_configuration WHERE plugin_definition_key = 'iko')
            AND type = 'iko';
        </sql>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
            <tableExists tableName="plugin_configuration"/>
            <tableExists tableName="iko_repository_config"/>
        </preConditions>

        <sql>
            UPDATE iko_repository_config
            SET properties = JSON_OBJECT('ikoServerUrl', (SELECT JSON_UNQUOTE(JSON_EXTRACT(properties, '$.url')) FROM plugin_configuration WHERE plugin_definition_key = 'iko' LIMIT 1))
            WHERE EXISTS (SELECT 1 FROM plugin_configuration WHERE plugin_definition_key = 'iko')
            AND type = 'iko';
        </sql>
    </changeSet>

    <changeSet author="Ritense" id="3">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="plugin_configuration"/>
        </preConditions>
        <comment>Delete iko plugin configuration</comment>
        <delete tableName="plugin_configuration">
            <where>plugin_definition_key = 'iko'</where>
        </delete>
    </changeSet>

</databaseChangeLog>
