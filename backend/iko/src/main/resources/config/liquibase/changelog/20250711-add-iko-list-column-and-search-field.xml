<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet author="Ritense" id="1">
        <createTable tableName="iko_data_aggregate_list_column">
            <column name="iko_data_aggregate_key" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="column_id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <addUniqueConstraint constraintName="unique-id-constraint-list"
                             columnNames="id"
                             tableName="search_list_column"/>
    </changeSet>

    <changeSet author="Ritense" id="3">
        <addForeignKeyConstraint baseTableName="iko_data_aggregate_list_column" baseColumnNames="iko_data_aggregate_key"
                                 constraintName="fk_iko_data_aggregate_list_column_data_aggregate_key"
                                 referencedTableName="iko_data_aggregate" referencedColumnNames="key"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet author="Ritense" id="4">
        <addForeignKeyConstraint baseTableName="iko_data_aggregate_list_column" baseColumnNames="column_id"
                                 constraintName="fk_iko_data_aggregate_list_column_id"
                                 referencedTableName="search_list_column" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet author="Ritense" id="5">
        <createTable tableName="iko_data_request_search_field">
            <column name="iko_data_aggregate_key" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="iko_data_request_key" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="search_field_id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="Ritense" id="6">
        <addUniqueConstraint constraintName="unique-id-constraint"
                             columnNames="id"
                             tableName="search_field_v2"/>
    </changeSet>

    <changeSet author="Ritense" id="7">
        <addForeignKeyConstraint baseTableName="iko_data_request_search_field" baseColumnNames="iko_data_request_key,iko_data_aggregate_key"
                                 constraintName="fk_iko_data_request_search_field_data_request_key"
                                 referencedTableName="iko_data_request" referencedColumnNames="key,iko_data_aggregate_key"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet author="Ritense" id="8">
        <addForeignKeyConstraint baseTableName="iko_data_request_search_field" baseColumnNames="search_field_id"
                                 constraintName="fk_iko_data_request_search_field_id"
                                 referencedTableName="search_field_v2" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>