<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="1" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <sql>
            UPDATE iko_data_aggregate
            SET properties =
                    (properties::jsonb - 'endpointPath') ||
                    jsonb_build_object(
                            'connectorTag', '',
                            'connectorInstanceTag', '',
                            'endpointOperation', properties::jsonb->>'endpointPath'
                    )
            WHERE jsonb_exists(properties::jsonb, 'endpointPath');
        </sql>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
            <sqlCheck expectedResult="1">
                SELECT version() >= 8.0
            </sqlCheck>
        </preConditions>
        <sql>
            UPDATE iko_data_aggregate
            SET properties = JSON_SET(
                    JSON_REMOVE(properties, '$.endpointPath'),
                    '$.connectorTag', '',
                    '$.connectorInstanceTag', '',
                    '$.endpointOperation', JSON_UNQUOTE(JSON_EXTRACT(properties, '$.endpointPath'))
                             )
            WHERE JSON_CONTAINS_PATH(properties, 'one', '$.endpointPath');
        </sql>
    </changeSet>

</databaseChangeLog>
