<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet author="Ritense" id="1">
        <createTable tableName="iko_repository_config">
            <column name="key" type="VARCHAR(256)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <createTable tableName="iko_data_aggregate">
            <column name="key" type="VARCHAR(256)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="iko_repository_config_key" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="iko_data_aggregate"
                                 baseColumnNames="iko_repository_config_key"
                                 referencedTableName="iko_repository_config"
                                 referencedColumnNames="key"
                                 constraintName="fk_iko_data_aggregate_iko_repository_config_key"
                                 onDelete="CASCADE"/>
    </changeSet>

    <changeSet author="Ritense" id="3">
        <createTable tableName="iko_data_request">
            <column name="key" type="VARCHAR(256)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="iko_data_aggregate_key" type="VARCHAR(256)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="iko_data_request_order" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="iko_data_request"
                                 baseColumnNames="iko_data_aggregate_key"
                                 referencedTableName="iko_data_aggregate"
                                 referencedColumnNames="key"
                                 constraintName="fk_iko_data_request_iko_data_aggregate_key"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
