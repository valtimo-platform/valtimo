<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet author="MvT" id="camunda-task-with-subtitles-view">
        <preConditions onFail="MARK_RAN">
            <viewExists viewName="act_ru_task_view" />
        </preConditions>

        <createView viewName="act_ru_task_view"
                    replaceIfExists="true">
            SELECT      art.*,
                        pl.subtitles
            FROM        act_ru_task AS art
            LEFT JOIN   process_link AS pl
                        ON pl.process_definition_id = art.proc_def_id_
                        AND pl.activity_id = art.task_def_key_
        </createView>
    </changeSet>

</databaseChangeLog>