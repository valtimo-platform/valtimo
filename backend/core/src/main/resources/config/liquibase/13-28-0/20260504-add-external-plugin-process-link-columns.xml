<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd"
                   logicalFilePath="config/liquibase/13-28-0/20260504-add-external-plugin-process-link-columns.xml">

    <changeSet author="Ritense" id="1">
        <preConditions onFail="CONTINUE">
            <tableExists tableName="process_link"/>
        </preConditions>
        <addColumn tableName="process_link">
            <column name="external_plugin_config_id" type="${uuidType}"/>
            <column name="external_plugin_action_key" type="VARCHAR(255)"/>
            <column name="external_plugin_action_properties" type="${jsonType}"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
