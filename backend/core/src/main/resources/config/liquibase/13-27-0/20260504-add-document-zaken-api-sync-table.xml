<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd"
                   logicalFilePath="config/liquibase/changelog/20260504-add-document-zaken-api-sync-table.xml">

    <changeSet author="Ritense" id="1">
        <createTable tableName="document_zaken_api_sync">
            <column name="id" type="${uuidType}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="document_zaken_api_syncPK"/>
            </column>
            <column name="case_definition_key" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="sync_assignee_as_behandelaar" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="note_sync_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="note_subject" type="VARCHAR(255)" defaultValue="Note created by Valtimo GZAC">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <addUniqueConstraint tableName="document_zaken_api_sync"
                             columnNames="case_definition_key, case_definition_version_tag"
                             constraintName="document_zaken_api_sync_case_definition_uq"/>
    </changeSet>

</databaseChangeLog>
