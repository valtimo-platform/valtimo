<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd"
                   logicalFilePath="config/liquibase/changelog/20260503-add-procdef-key-tenant-version-index.xml">

    <changeSet author="Erik de Vries" id="1">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="ACT_RE_PROCDEF"/>
            <not>
                <indexExists indexName="ACT_IDX_PROCDEF_KEY_TENANT_VER"/>
            </not>
        </preConditions>
        <createIndex indexName="ACT_IDX_PROCDEF_KEY_TENANT_VER"
                     tableName="ACT_RE_PROCDEF"
                     unique="false">
            <column name="KEY_"/>
            <column name="TENANT_ID_"/>
            <column name="VERSION_"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
