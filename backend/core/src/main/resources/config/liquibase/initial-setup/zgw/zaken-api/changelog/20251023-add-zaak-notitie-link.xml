<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd" logicalFilePath="config/liquibase/changelog/20251023-add-zaak-notitie-link.xml">

    <changeSet id="1" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="zaak_notitie_link"/>
            </not>
        </preConditions>
        <createTable tableName="zaak_notitie_link">
            <column name="zaak_notitie_link_id" type="${uuidType}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="zaak_notitie_linkPK"/>
            </column>
            <column name="zaak_notitie_url" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="note_id" type="${uuidType}">
                <constraints nullable="true"/>
            </column>
            <column name="document_id" type="${uuidType}">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
