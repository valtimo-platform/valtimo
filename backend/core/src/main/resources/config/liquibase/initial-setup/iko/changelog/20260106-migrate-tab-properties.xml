<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd" logicalFilePath="config/liquibase/changelog/20260106-migrate-tab-properties.xml">

    <changeSet id="1" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
            <columnExists tableName="tab" columnName="properties"/>
        </preConditions>
        <sql>
            UPDATE tab
            SET properties = jsonb_build_object('aggregatedDataProfileName', iv.properties ->> 'aggregatedDataProfileName')
                FROM iko_view_tab ivt
            JOIN iko_view iv ON ivt.iko_view_key = iv.key
            WHERE tab.id = ivt.tab_id
              AND iv.properties::jsonb ?? 'aggregatedDataProfileName';
        </sql>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
            <columnExists tableName="tab" columnName="properties"/>
        </preConditions>
        <sql>
            UPDATE tab
                JOIN iko_view_tab ivt ON tab.id = ivt.tab_id
                JOIN iko_view iv ON ivt.iko_view_key = iv.key
                SET tab.properties = JSON_OBJECT('aggregatedDataProfileName', JSON_UNQUOTE(JSON_EXTRACT(iv.properties, '$.aggregatedDataProfileName')))
            WHERE JSON_CONTAINS_PATH(iv.properties, 'one', '$.aggregatedDataProfileName');
        </sql>
    </changeSet>

</databaseChangeLog>
