<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd" logicalFilePath="config/liquibase/changelog/20250601-create-building-block-process-link.xml">


    <changeSet id="1" author="Ritense">
        <validCheckSum>9:b184e6b64822c6d158764c66c92a80e4</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="process_link"/>
        </preConditions>

        <createTable tableName="building_block_process_link">
            <column name="process_link_id" type="${uuidType}">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="building_block_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="building_block_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="plugin_configuration_mappings" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="building_block_process_link"
            baseColumnNames="process_link_id"
            referencedTableName="process_link"
            referencedColumnNames="id"
            onDelete="CASCADE"
            constraintName="fk_bb_process_link_base"/>

        <createIndex indexName="idx_bb_process_link_bb" tableName="building_block_process_link">
            <column name="building_block_definition_key"/>
            <column name="building_block_definition_version_tag"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
