<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="1" author="Ritense">
        <createTable tableName="team">
            <column name="team_key" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_team"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <createTable tableName="team_user">
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="team_key" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="team_user" columnNames="username, team_key" constraintName="pk_team_user"/>

        <addForeignKeyConstraint baseColumnNames="team_key"
                                 baseTableName="team_user"
                                 constraintName="fk_team_user_team"
                                 referencedColumnNames="team_key"
                                 referencedTableName="team"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
