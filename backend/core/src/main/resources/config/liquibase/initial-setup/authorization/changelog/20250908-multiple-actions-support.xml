<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd" logicalFilePath="config/liquibase/changelog/20250908-multiple-actions-support.xml">

    <changeSet author="Ritense" id="1">
        <createTable tableName="permission_actions">
            <column name="permission_id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
            tableName="permission_actions"
            columnNames="permission_id, action"
            constraintName="pk_permission_actions"/>

        <addForeignKeyConstraint
            baseTableName="permission_actions"
            baseColumnNames="permission_id"
            referencedTableName="permission"
            referencedColumnNames="id"
            onDelete="CASCADE"
            constraintName="fk_permission_actions_permission"/>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <sql stripComments="true" splitStatements="true">
            INSERT INTO permission_actions (permission_id, action)
            SELECT p.id, p.action
            FROM permission p
            WHERE p.action IS NOT NULL;
        </sql>
    </changeSet>

    <changeSet author="Ritense" id="3">
        <dropColumn tableName="permission" columnName="action"/>
    </changeSet>

</databaseChangeLog>