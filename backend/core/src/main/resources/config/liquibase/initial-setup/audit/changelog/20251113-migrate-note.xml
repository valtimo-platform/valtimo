<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd" logicalFilePath="config/liquibase/changelog/20251113-migrate-note.xml">

    <changeSet author="Ritense" id="1">
        <validCheckSum>9:d1130babc4ec8025573e13d4fb1a7879</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <sql>
            UPDATE audit_record
            SET audit_event = jsonb_set(
                audit_event::jsonb,
                '{className}',
                to_jsonb(
                    replace(
                        audit_event->>'className',
                        'com.ritense.note.event.',
                        'com.ritense.valtimo.contract.event.'
                    )
                ),
                false
            )::json
            WHERE classname LIKE 'com.ritense.note.event.%';
        </sql>
    </changeSet>

    <changeSet author="Ritense" id="2">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <sql>
            UPDATE audit_record
            SET audit_event = JSON_SET(
                audit_event,
                '$.className',
                REPLACE(
                    JSON_UNQUOTE(JSON_EXTRACT(audit_event, '$.className')),
                    'com.ritense.note.event.',
                    'com.ritense.valtimo.contract.event.'
                )
            )
            WHERE classname LIKE 'com.ritense.note.event.%';
        </sql>
    </changeSet>

</databaseChangeLog>
