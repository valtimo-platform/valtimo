<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd" logicalFilePath="config/liquibase/changelog/20250704-add-widget-table.xml">


    <changeSet id="1" author="Ritense">
        <validCheckSum>9:8aa8a21d2fc6960d361492e395f34fd1</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <createTable tableName="widget">
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="widget_key" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="widget_type" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="widget_order" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="width" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="high_contrast" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
            <column name="actions" type="${jsonType}" defaultValue="[]">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <validCheckSum>9:ae4aed475c84144d46ddbf46683b524b</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <createTable tableName="widget">
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="widget_key" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="false"/>
            </column>
            <column name="widget_type" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="widget_order" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="width" type="${intType}">
                <constraints nullable="false"/>
            </column>
            <column name="high_contrast" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="properties" type="${jsonType}">
                <constraints nullable="false"/>
            </column>
            <column name="actions" type="${jsonType}">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="5" author="Ritense">
        <update tableName="widget">
            <column name="actions" value="[]"/>
        </update>
    </changeSet>

    <changeSet id="6" author="Ritense">
        <validCheckSum>9:7fd07de4ac4bacc7b2c66d67423f56c5</validCheckSum>
        <addNotNullConstraint
                tableName="widget"
                columnName="actions"
                columnDataType="${jsonType}"
        />
    </changeSet>


</databaseChangeLog>
