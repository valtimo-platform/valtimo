<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd" logicalFilePath="config/liquibase/changelog/20260106-add-tab-properties.xml">


    <changeSet id="1" author="Ritense">
        <validCheckSum>9:d7f526eea8c71bac58ad58e714db8c72</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <addColumn tableName="tab">
            <column name="properties" type="${jsonType}" defaultValue="{}">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <validCheckSum>9:ba69a8204647b7b7749ea52f74e90858</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <addColumn tableName="tab">
            <column name="properties" type="${jsonType}">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <update tableName="tab">
            <column name="properties" value="{}"/>
        </update>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <validCheckSum>9:ca5a8555b4bd568fd12f77892f19a967</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <addNotNullConstraint tableName="tab" columnName="properties" columnDataType="${jsonType}"/>
    </changeSet>

</databaseChangeLog>
