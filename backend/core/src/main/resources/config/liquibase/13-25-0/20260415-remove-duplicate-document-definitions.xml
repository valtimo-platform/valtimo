<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd"
                   logicalFilePath="config/liquibase/changelog/20260415-remove-duplicate-document-definitions.xml">

    <changeSet author="Ritense" id="1">
        <sql>
            DELETE FROM json_schema_document_definition a
            WHERE a.document_definition_name != a.blueprint_key
              AND EXISTS (
                  SELECT 1
                  FROM json_schema_document_definition b
                  WHERE b.blueprint_type = a.blueprint_type
                    AND b.blueprint_key = a.blueprint_key
                    AND b.blueprint_version_tag = a.blueprint_version_tag
                    AND b.document_definition_name = b.blueprint_key
              )
        </sql>
    </changeSet>
</databaseChangeLog>
