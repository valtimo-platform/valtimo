<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="1" author="Ritense">
        <createTable tableName="startable_item">
            <column name="case_definition_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="item_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="item_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="startable_item"
                       columnNames="case_definition_key, case_definition_version_tag, item_key, item_type"/>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <validCheckSum>9:a02856f384583fa12b599f9632c6e4bf</validCheckSum>
        <dropPrimaryKey tableName="startable_item"/>
        <addColumn tableName="startable_item">
            <column name="item_version_tag" type="VARCHAR(200)" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <!-- Primary key moved to 20260410-fix-mysql-key-length.xml (columns must be shrunk first for MySQL) -->
    </changeSet>

</databaseChangeLog>
