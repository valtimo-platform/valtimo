<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd"
                   logicalFilePath="config/liquibase/changelog/20260310-add-case-definition-configuration-issue-table.xml">

    <changeSet author="Ritense" id="1">
        <createTable tableName="case_definition_configuration_issue">
            <column name="id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
            <column name="case_definition_key" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="case_definition_version_tag" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="issue_type" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="resolved" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="case_definition_configuration_issue"
                       columnNames="id"
                       constraintName="pk_case_def_config_issue"/>

        <createIndex indexName="idx_case_def_config_issue_case_def"
                     tableName="case_definition_configuration_issue">
            <column name="case_definition_key"/>
            <column name="case_definition_version_tag"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
