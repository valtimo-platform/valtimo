<configuration scan="true">
    <include resource="config/logging/logback/valtimo-defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />
    <include resource="config/logging/logback/valtimo-database-appender.xml" />

    <logger name="com.ritense.valtimo" level="#logback.loglevel#"/>
    <logger name="com.ritense.document.mongodb" level="DEBUG"/>
    <logger name="com.ritense.valtimo.web.logging" level="DEBUG"/>

    <logger name="ch.qos.logback" level="WARN"/>
    <logger name="com.amazonaws" level="WARN"/>
    <logger name="com.codahale.metrics" level="WARN"/>
    <logger name="com.github.dockerjava" level="WARN"/>
    <logger name="com.ritense.valtimo.config.testcontainer" level="WARN"/>
    <logger name="com.ryantenney" level="WARN"/>
    <logger name="com.sun" level="WARN"/>
    <logger name="com.zaxxer" level="WARN"/>
    <logger name="io.hypersistence.utils.hibernate" level="WARN"/>
    <logger name="jakarta.activation" level="WARN"/>
    <logger name="jakarta.mail" level="WARN"/>
    <logger name="jakarta.xml.bind" level="WARN"/>
    <logger name="javax.management.remote.rmi" level="WARN"/>
    <logger name="liquibase" level="WARN"/>
    <logger name="net.sf.ehcache" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>
    <logger name="org.apache" level="WARN"/>
    <logger name="org.apache.catalina.startup.DigesterFactory" level="OFF"/>
    <logger name="org.bson" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.ejb.HibernatePersistence" level="OFF"/>
    <logger name="org.hibernate.engine.jdbc.spi" level="INFO"/>
    <logger name="org.hibernate.validator" level="WARN"/>
    <logger name="org.operaton" level="INFO"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.cache" level="WARN"/>
    <logger name="org.springframework.cloud" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.springframework.security.web.access" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.testcontainers" level="INFO"/>
    <logger name="org.thymeleaf" level="WARN"/>
    <logger name="org.xnio" level="WARN"/>
    <logger name="springfox" level="WARN"/>
    <logger name="sun.rmi" level="WARN"/>
    <logger name="sun.rmi.transport" level="WARN"/>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <root level="#logback.loglevel#">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="VALTIMODBASYNC"/>
    </root>

</configuration>
