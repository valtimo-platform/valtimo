{
    "display": "form",
    "components": [
        {
            "key": "pv.caseDefinitionKey",
            "type": "hidden",
            "input": true,
            "label": "set case definition key",
            "tableView": false,
            "defaultValue": false,
            "calculateValue": "const [before, after]=window.location.href.split('/cases/');[value, rest]=after.split('/');",
            "attributes": {
                "data-testid": "user-task-set-internal-case-status-caseDefinitionKey"
            }
        },
        {
            "key": "pv.internalStatusType",
            "data": {
                "url": "../api/management/v1/case-definition/{{data.pv.caseDefinitionKey}}/internal-status",
                "method": "GET",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{localStorage.getItem('formioToken')}}"
                    }
                ]
            },
            "type": "select",
            "input": true,
            "label": "template",
            "widget": "choicesjs",
            "dataSrc": "url",
            "template": "<span>{{ item.key }}</span>",
            "validate": {
                "required": true
            },
            "refreshOn": "pv.caseDefinitionKey",
            "tableview": true,
            "attributes": {
                "data-testid": "user-task-set-internal-case-status-pv.internalStatusType"
            },
            "disableLimit": false,
            "selectValues": "content",
            "valueProperty": "key",
            "clearOnRefresh": true,
            "customConditional": "show = data.pv.caseDefinitionKey ? true : false;",
            "noRefreshOnScroll": false
        },
        {
            "key": "submit",
            "type": "button",
            "input": true,
            "label": "Submit",
            "tableView": false,
            "disableOnInvalid": true
        }
    ]
}