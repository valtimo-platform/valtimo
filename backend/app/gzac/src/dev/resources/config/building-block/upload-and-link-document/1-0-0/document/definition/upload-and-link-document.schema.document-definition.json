{
    "$id": "upload-and-link-document.schema",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Upload document naar documenten API en koppelen aan een zaak",
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "description": "Title of the document"
        },
        "description": {
            "type": "string",
            "description": "Omschrijving document"
        },
        "fileName": {
            "type": "string",
            "description": "bestandsnaam"
        },
        "confidentialityLevel": {
            "type": "string",
            "description": "confidentiality Level document"
        },
        "temporaryDocumentId": {
            "type": "string",
            "description": "Id of temporary stored document"
        },
        "informationObjectTypeUrl": {
            "type": "string",
            "description": "Informatie object type url"
        }
    }
}
