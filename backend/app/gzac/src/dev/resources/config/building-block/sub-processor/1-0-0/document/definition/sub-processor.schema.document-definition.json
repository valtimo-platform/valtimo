{
    "$id": "sub-processor.schema",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Sub-Processor Document",
    "type": "object",
    "properties": {
        "dataToProcess": {
            "type": "string",
            "description": "Input data from parent building block"
        },
        "numberToProcess": {
            "type": "integer",
            "description": "Input number from parent building block"
        },
        "transformedInput": {
            "type": "string",
            "description": "Result of transforming the input data to uppercase"
        },
        "enrichedData": {
            "type": "string",
            "description": "Enriched data from secondary process"
        },
        "processedData": {
            "type": "string",
            "description": "Processed output data"
        },
        "computedNumber": {
            "type": "integer",
            "description": "Computed number result (doubled input number)"
        },
        "subProcessResult": {
            "type": "string",
            "description": "Result from internal sub-process"
        },
        "deepAggregationResult": {
            "type": "string",
            "description": "Result from deep-aggregator building block"
        }
    },
    "required": ["dataToProcess", "numberToProcess"]
}
