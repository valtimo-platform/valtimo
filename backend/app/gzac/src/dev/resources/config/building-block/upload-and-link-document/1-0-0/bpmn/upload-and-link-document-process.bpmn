      <bpmn:incoming>Flow_0t2bxg8</bpmn:incoming>
      <bpmn:outgoing>Flow_0wmnep7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="SecondCheckTask" name="check" implementation="##unspecified">
      <bpmn:incoming>Flow_0wmnep7</bpmn:incoming>
      <bpmn:outgoing>Flow_17qrvlq</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0pluhoi">
      <bpmn:incoming>Flow_17qrvlq</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
