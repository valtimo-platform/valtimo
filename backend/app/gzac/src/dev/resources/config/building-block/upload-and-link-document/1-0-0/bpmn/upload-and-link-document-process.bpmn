  <bpmn:process id="upload-and-link-document-process" name="Bestand koppelen" processType="None" isClosed="false" isExecutable="true" camunda:versionTag="CD:bezwaar:1.0.1">
    <bpmn:sequenceFlow id="Flow_11vuyzp" sourceRef="StartEvent" targetRef="UploadToDocumentenAPITask" />
    <bpmn:sequenceFlow id="Flow_17qrvlq" sourceRef="SecondCheckTask" targetRef="Event_0pluhoi" />
    <bpmn:sequenceFlow id="Flow_0wmnep7" sourceRef="LinkToCaseTask" targetRef="SecondCheckTask" />
