    <bpmn:startEvent id="StartEvent" name="starten maar">
      <bpmn:outgoing>Flow_11vuyzp</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="UploadToDocumentenAPITask" name="Upload document" implementation="##WebService" camunda:expression="${true}">
      <bpmn:incoming>Flow_11vuyzp</bpmn:incoming>
      <bpmn:outgoing>Flow_0t2bxg8</bpmn:outgoing>
    </bpmn:serviceTask>
