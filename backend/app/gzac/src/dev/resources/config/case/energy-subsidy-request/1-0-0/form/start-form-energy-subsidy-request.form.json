{
    "display": "form",
    "components": [
        {
            "label": "HTML",
            "tag": "h3",
            "content": "Energietoeslag Aanvraag",
            "refreshOnChange": false,
            "key": "html-title",
            "type": "htmlelement",
            "input": false,
            "tableView": false
        },
        {
            "label": "HTML",
            "content": "Vul uw gegevens in om de energietoeslag aan te vragen. Uw aanvraag wordt automatisch gecontroleerd via huishoudenverificatie en inkomenstoets.",
            "refreshOnChange": false,
            "key": "html-description",
            "type": "htmlelement",
            "input": false,
            "tableView": false
        },
        {
            "label": "Naam aanvrager",
            "placeholder": "Vul uw volledige naam in...",
            "tableView": true,
            "validate": {
                "required": true,
                "minLength": 2
            },
            "key": "applicantName",
            "type": "textfield",
            "input": true
        },
        {
            "label": "Aantal personen in huishouden",
            "placeholder": "Aantal personen inclusief uzelf...",
            "tableView": true,
            "validate": {
                "required": true,
                "min": 1
            },
            "key": "householdSize",
            "type": "number",
            "input": true
        },
        {
            "label": "HTML",
            "tag": "h4",
            "content": "Adresgegevens",
            "refreshOnChange": false,
            "key": "html-address-title",
            "type": "htmlelement",
            "input": false,
            "tableView": false
        },
        {
            "label": "Woonplaats",
            "placeholder": "Vul uw woonplaats in...",
            "tableView": true,
            "key": "applicant.address.city",
            "type": "textfield",
            "input": true
        },
        {
            "label": "Postcode",
            "placeholder": "1234 AB",
            "tableView": true,
            "key": "applicant.address.postalCode",
            "type": "textfield",
            "input": true
        },
        {
            "type": "button",
            "label": "Aanvraag Indienen",
            "key": "submit",
            "disableOnInvalid": true,
            "input": true,
            "tableView": false
        }
    ]
}
