{
    "$id": "aggregation-demo.schema",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Aggregation Demo",
    "type": "object",
    "properties": {
        "inputText": {
            "type": "string",
            "description": "Text input for data transformation"
        },
        "inputNumber": {
            "type": "integer",
            "description": "Number input for processing"
        },
        "transformedText": {
            "type": "string",
            "description": "Result: Transformed text from building block"
        },
        "processedNumber": {
            "type": "integer",
            "description": "Result: Processed number from building block"
        },
        "aggregatedResult": {
            "type": "string",
            "description": "Result: Final aggregated result from nested building blocks"
        }
    },
    "required": ["inputText", "inputNumber"]
}
