{
    "display": "form",
    "components": [
        {
            "type": "iko-search",
            "key": "ikoSearchResult",
            "label": "Zoek in IKO",
            "hideLabel": true,
            "customOptions": {
                "ikoViewKey": "demo"
            },
            "input": true,
            "tableView": true
        },
        {
            "type": "button",
            "key": "submit",
            "label": "Versturen",
            "input": true,
            "action": "custom",
            "disableOnInvalid": true,
            "custom": "window.open('/iko/demo/bsn/details/' + data.ikoSearchResult, '_blank'); form.submit();"
        }
    ]
}
