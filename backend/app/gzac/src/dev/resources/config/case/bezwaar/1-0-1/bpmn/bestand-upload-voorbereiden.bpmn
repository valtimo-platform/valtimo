      <bpmn:outgoing>Flow_11vuyzp</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="SetContentTask" name="set content" implementation="##WebService" camunda:expression="${execution.setVariable(&#39;testcontent&#39;, valueResolverDelegateService.resolveValue(execution, &#39;doc:voornaam&#39;))}">
      <bpmn:incoming>Flow_11vuyzp</bpmn:incoming>
      <bpmn:outgoing>Flow_08p7bm9</bpmn:outgoing>
