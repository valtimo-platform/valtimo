    <bpmn:callActivity id="CallUploadAndLinkBB" name="Call Upload and Link BB" calledElement="upload-and-link-document-process" camunda:calledElementBinding="versionTag" camunda:calledElementVersionTag="BB:upload-and-link-document:1.0.0">
      <bpmn:extensionElements>
