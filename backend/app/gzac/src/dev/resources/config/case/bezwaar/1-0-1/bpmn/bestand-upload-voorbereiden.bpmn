    <bpmn:sequenceFlow id="Flow_11vuyzp" sourceRef="BestandUploadVoorbereidenStartTask" targetRef="SetContentTask" />
    <bpmn:sequenceFlow id="Flow_08p7bm9" sourceRef="SetContentTask" targetRef="StoreContentTask" />
    <bpmn:sequenceFlow id="Flow_0a4d81k" sourceRef="StoreContentTask" targetRef="CallUploadAndLinkBB" />
    <bpmn:sequenceFlow id="Flow_0ob11xp" sourceRef="CallUploadAndLinkBB" targetRef="Event_0pluhoi" />
