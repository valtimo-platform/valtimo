    </bpmn:callActivity>
    <bpmn:serviceTask id="StoreContentTask" name="Store content" implementation="##WebService" camunda:expression="${resourceStorageDelegate.storeResolvableContent(&#39;pv:testcontent&#39;)}" camunda:resultVariable="textResourceId">
