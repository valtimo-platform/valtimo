<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="Ritense" id="1">
        <createTable tableName="document_objecten_api_sync">
            <column name="id" type="${uuidType}">
                <constraints nullable="false" primaryKey="true" primaryKeyName="document_objecten_api_syncPK"/>
            </column>
            <column name="object_management_configuration_id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
            <column name="document_definition_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="document_definition_version" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <addColumn tableName="document_objecten_api_sync">
            <column name="case_definition_key" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <sql>
            update document_objecten_api_sync
            set case_definition_key = document_definition_name,
                case_definition_version_tag = '000000.' || LPAD(document_definition_version::text, 6, '0') || '.000000-${environmentName}'
            where case_definition_version_tag is null
        </sql>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <dropColumn tableName="document_objecten_api_sync" columnName="document_definition_name"/>
        <dropColumn tableName="document_objecten_api_sync" columnName="document_definition_version"/>
    </changeSet>

    <changeSet id="5" author="Ritense">
        <addNotNullConstraint tableName="document_objecten_api_sync" columnName="case_definition_key"/>
        <addNotNullConstraint tableName="document_objecten_api_sync" columnName="case_definition_version_tag"/>
    </changeSet>

</databaseChangeLog>