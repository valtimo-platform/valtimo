<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="1" author="Ritense">
        <createTable tableName="notificaties_api_inbound_event">
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idempotence_key" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="pending_retries" type="int"/>
            <column name="last_processed_at" type="datetime"/>
            <column name="last_error_message" type="CLOB"/>
            <column name="received_at" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="next_due_at" type="datetime"/>
        </createTable>

        <addUniqueConstraint tableName="notificaties_api_inbound_event"
                              columnNames="idempotence_key"
                              constraintName="uk_notif_inbound_event_idempotence_key"/>

        <createIndex tableName="notificaties_api_inbound_event"
                     indexName="idx_notif_inbound_event_next_due_at">
            <column name="next_due_at"/>
        </createIndex>

        <createIndex tableName="notificaties_api_inbound_event"
                     indexName="idx_notif_inbound_event_status_received_at">
            <column name="status"/>
            <column name="received_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
