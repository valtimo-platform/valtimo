<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="1" author="Ritense">
        <dropUniqueConstraint tableName="zaak_type_link" constraintName="zaak_type_url_constraint"/>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <renameColumn tableName="zaak_type_link"
                      oldColumnName="document_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(50)"/>

        <addColumn tableName="zaak_type_link">
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="25" author="Ritense">
        <sql>
            insert into zaak_type_link (
                zaak_type_link_id,
                case_definition_key,
                case_definition_version_tag,
                zaak_type_url,
                create_with_dossier,
                zaken_api_plugin_configuration_id,
                rsin
            )
            select
                gen_random_uuid(),
                ztl.case_definition_key,
                cd.case_definition_version_tag,
                ztl.zaak_type_url,
                ztl.create_with_dossier,
                ztl.zaken_api_plugin_configuration_id,
                ztl.rsin
            from zaak_type_link ztl
            join case_definition cd
                on ztl.case_definition_key = cd.case_definition_key
            where ztl.case_definition_version_tag is null
        </sql>
        <sql>
            delete from zaak_type_link
            where case_definition_version_tag is null
        </sql>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <addUniqueConstraint tableName="zaak_type_link"
                             columnNames="case_definition_key, case_definition_version_tag, zaak_type_url"
                             constraintName="zaak_type_url_constraint"
        />
    </changeSet>

</databaseChangeLog>
