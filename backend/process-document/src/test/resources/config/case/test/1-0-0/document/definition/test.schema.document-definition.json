            "anyOf": [
                {"type": "string"},
                {"type": "null"}
            ]
        },
        "string5": {
            "oneOf": [
                {"type": "string"},
                {"type": "integer"},
                {"type": "null"}
            ]
        },
        "string6": {
            "type": ["string", "integer"]
        },
        "enum1": {
            "enum": ["DEBET", "CREDIT"],
            "type": "string",
            "default": "DEBET"
        },
        "enum2": {
            "type": "array",
            "items": {
                "enum": ["BALIE", "TELEFONIE", "INTERNET", "POST"],
                "type": "string"
