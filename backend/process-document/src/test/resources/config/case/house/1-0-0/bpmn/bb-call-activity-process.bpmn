<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_bb_test" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.2.0">
  <bpmn:collaboration id="Collaboration_bb_test">
    <bpmn:participant id="Participant_parent" name="BB parent process" processRef="bb-parent-process" />
    <bpmn:participant id="Participant_sub" name="BB sub process" processRef="bb-sub-process" />
  </bpmn:collaboration>
  <bpmn:process id="bb-parent-process" name="BB parent process" isExecutable="true">
    <bpmn:startEvent id="bb-parent-start">
      <bpmn:outgoing>flow1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="flow1" sourceRef="bb-parent-start" targetRef="bb-call-activity" />
    <bpmn:callActivity id="bb-call-activity" name="Call building block" calledElement="bb-sub-process">
      <bpmn:extensionElements>
        <camunda:in businessKey="#{bbDocumentId}" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow1</bpmn:incoming>
      <bpmn:outgoing>flow2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="bb-parent-end">
      <bpmn:incoming>flow2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow2" sourceRef="bb-call-activity" targetRef="bb-parent-end" />
  </bpmn:process>
  <bpmn:process id="bb-sub-process" name="BB sub process" isExecutable="true">
    <bpmn:startEvent id="bb-sub-start">
      <bpmn:outgoing>flow3</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="flow3" sourceRef="bb-sub-start" targetRef="bb-user-task" />
    <bpmn:userTask id="bb-user-task" name="building block user task" camunda:candidateGroups="ROLE_USER">
      <bpmn:incoming>flow3</bpmn:incoming>
      <bpmn:outgoing>flow4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="bb-sub-end">
      <bpmn:incoming>flow4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow4" sourceRef="bb-user-task" targetRef="bb-sub-end" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_bb_test">
      <bpmndi:BPMNShape id="Participant_parent_di" bpmnElement="Participant_parent" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="460" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-parent-start_di" bpmnElement="bb-parent-start">
        <dc:Bounds x="220" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-call-activity_di" bpmnElement="bb-call-activity">
        <dc:Bounds x="310" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-parent-end_di" bpmnElement="bb-parent-end">
        <dc:Bounds x="472" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow1_di" bpmnElement="flow1">
        <di:waypoint x="256" y="180" />
        <di:waypoint x="310" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_di" bpmnElement="flow2">
        <di:waypoint x="410" y="180" />
        <di:waypoint x="472" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_sub_di" bpmnElement="Participant_sub" isHorizontal="true">
        <dc:Bounds x="160" y="340" width="460" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-sub-start_di" bpmnElement="bb-sub-start">
        <dc:Bounds x="220" y="422" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-user-task_di" bpmnElement="bb-user-task">
        <dc:Bounds x="310" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bb-sub-end_di" bpmnElement="bb-sub-end">
        <dc:Bounds x="472" y="422" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow3_di" bpmnElement="flow3">
        <di:waypoint x="256" y="440" />
        <di:waypoint x="310" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_di" bpmnElement="flow4">
        <di:waypoint x="410" y="440" />
        <di:waypoint x="472" y="440" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>