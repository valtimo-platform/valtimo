<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <renameTable oldTableName="document_definition_process_link" newTableName="case_definition_process_link"/>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <renameColumn tableName="case_definition_process_link"
                      oldColumnName="document_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(50)"/>
        <addColumn tableName="case_definition_process_link">
            <column name="case_definition_version_tag" type="VARCHAR(200)"/>
        </addColumn>
    </changeSet>

    <!-- This is only used temporarily during migration to major 13 -->
    <changeSet id="3" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="form_io_form_definition"/>
            <tableExists tableName="process_link"/>
        </preConditions>
        <addColumn tableName="process_link">
            <column name="migration_form_name" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="form_io_form_definition"/>
            <tableExists tableName="process_link"/>
        </preConditions>
        <customChange class="com.ritense.processdocument.liquibase.changelog.ChangeLog20250514MigrateProcessDefinitions"/>
    </changeSet>

    <changeSet id="5" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
        </preConditions>
        <sql>
            update act_ru_event_subscr es
            set configuration_ = pd2.id_
            from act_re_procdef pd
            join act_re_procdef pd2
                on pd.key_ = pd2.key_
            join (
                select key_, max(version_) as version_
                from act_re_procdef pd3
                group by key_
            ) as latest_version
                on pd2.key_ = latest_version.key_
                and pd2.version_ = latest_version.version_
            where es.configuration_ = pd.id_
        </sql>
    </changeSet>

    <changeSet id="6" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <dbms type="mysql"/>
        </preConditions>
        <sql>
            update act_ru_event_subscr es
            join act_re_procdef pd
                on es.configuration_ = pd.id_
            join act_re_procdef pd2
                on pd.key_ = pd2.key_
            join (
                select key_, max(version_) as version_
                from act_re_procdef pd3
                group by key_
            ) as latest_version
                on pd2.key_ = latest_version.key_
                and pd2.version_ = latest_version.version_
            set es.configuration_ = pd2.id_
        </sql>
    </changeSet>

</databaseChangeLog>
