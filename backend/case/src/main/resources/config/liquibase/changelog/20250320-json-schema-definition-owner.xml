<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <addColumn tableName="json_schema_document_definition">
            <column name="solution_module_type" type="VARCHAR(40)"/>
            <column name="solution_module_key" type="VARCHAR(256)"/>
            <column name="solution_module_version_tag" type="VARCHAR(200)"/>
        </addColumn>
        <sql>
            update json_schema_document_definition
            set solution_module_type = 'CASE',
                solution_module_key = case_definition_key,
                solution_module_version_tag = case_definition_version_tag
        </sql>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="solution_module_type" columnDataType="VARCHAR(40)"/>
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="solution_module_key" columnDataType="VARCHAR(256)"/>
        <addNotNullConstraint tableName="json_schema_document_definition" columnName="solution_module_version_tag" columnDataType="VARCHAR(200)"/>
        <dropColumn tableName="json_schema_document_definition" columnName="case_definition_key"/>
        <dropColumn tableName="json_schema_document_definition" columnName="case_definition_version_tag"/>
        <dropPrimaryKey tableName="json_schema_document_definition"/>
        <addPrimaryKey tableName="json_schema_document_definition" constraintName="pk_json_schema_document_definition"
                       columnNames="document_definition_name, solution_module_type, solution_module_key, solution_module_version_tag"/>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <addColumn tableName="json_schema_document">
            <column name="solution_module_type" type="VARCHAR(40)"/>
            <column name="solution_module_key" type="VARCHAR(256)"/>
            <column name="solution_module_version_tag" type="VARCHAR(200)"/>
        </addColumn>
        <sql>
            update json_schema_document
            set solution_module_type = 'CASE',
                solution_module_key = case_definition_key,
                solution_module_version_tag = case_definition_version_tag
        </sql>
        <addNotNullConstraint tableName="json_schema_document" columnName="solution_module_type" columnDataType="VARCHAR(40)"/>
        <addNotNullConstraint tableName="json_schema_document" columnName="solution_module_key" columnDataType="VARCHAR(256)"/>
        <addNotNullConstraint tableName="json_schema_document" columnName="solution_module_version_tag" columnDataType="VARCHAR(200)"/>
        <dropColumn tableName="json_schema_document" columnName="case_definition_key"/>
        <dropColumn tableName="json_schema_document" columnName="case_definition_version_tag"/>
        <addForeignKeyConstraint constraintName="fk_json_document_definition_solution_module"
                                 baseTableName="json_schema_document"
                                 baseColumnNames="document_definition_name, solution_module_type, solution_module_key, solution_module_version_tag"
                                 referencedTableName="json_schema_document_definition"
                                 referencedColumnNames="document_definition_name, solution_module_type, solution_module_key, solution_module_version_tag"/>
    </changeSet>
</databaseChangeLog>
