<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <renameColumn tableName="case_list_column"
                      oldColumnName="case_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(256)"/>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <dropForeignKeyConstraint baseTableName="case_widget_tab" constraintName="fk_case_widget_tab_case_tab"/>
        <dropForeignKeyConstraint baseTableName="case_widget_tab_widget" constraintName="fk_case_widget_tab_name_key"/>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <renameColumn tableName="case_tab"
                      oldColumnName="case_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(256)"/>
        <addColumn tableName="case_tab">
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <dropPrimaryKey tableName="case_tab"/>

        <sql>
            insert into case_tab
            (
                case_definition_key,
                case_definition_version_tag,
                tab_key,
                name,
                tab_order,
                type,
                content_key,
                created_by,
                created_on,
                show_tasks
            )
            select
                ct.case_definition_key,
                cd.case_definition_version_tag,
                ct.tab_key,
                ct.name,
                ct.tab_order,
                ct.type,
                ct.content_key,
                ct.created_by,
                ct.created_on,
                ct.show_tasks
            from case_tab ct
                     join case_definition cd
                          on cd.case_definition_key = ct.case_definition_key
        </sql>

        <renameColumn tableName="case_widget_tab"
                      oldColumnName="case_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(256)"/>
        <addColumn tableName="case_widget_tab">
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <dropPrimaryKey tableName="case_widget_tab"/>

        <sql>
            insert into case_widget_tab
            (
                case_definition_key,
                case_definition_version_tag,
                tab_key
            )
            select
                ct.case_definition_key,
                ct.case_definition_version_tag,
                cwt.tab_key
            from case_widget_tab cwt
            join case_tab ct
                on cwt.case_definition_key = ct.case_definition_key and cwt.tab_key = ct.tab_key
                and ct.case_definition_version_tag is not null
        </sql>

        <renameColumn tableName="case_widget_tab_widget"
                      oldColumnName="case_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="VARCHAR(256)"/>
        <addColumn tableName="case_widget_tab_widget">
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <dropPrimaryKey tableName="case_widget_tab_widget"/>

        <sql>
            insert into case_widget_tab_widget
            (
             key,
             title,
             case_widget_type,
             case_definition_key,
             case_definition_version_tag,
             tab_key,
             sort_order,
             width,
             high_contrast,
             properties,
             actions
            )
            select
                cwtw.key,
                cwtw.title,
                cwtw.case_widget_type,
                cwtw.case_definition_key,
                cwt.case_definition_version_tag,
                cwtw.tab_key,
                cwtw.sort_order,
                cwtw.width,
                cwtw.high_contrast,
                cwtw.properties,
                cwtw.actions
            from case_widget_tab_widget cwtw
            join case_widget_tab cwt on cwtw.case_definition_key = cwt.case_definition_key and cwtw.tab_key = cwt.tab_key
            where cwt.case_definition_version_tag is not null
        </sql>

        <sql>
            delete from case_widget_tab_widget
            where case_definition_version_tag is null
        </sql>

        <sql>
            delete from case_widget_tab
            where case_definition_version_tag is null
        </sql>

        <sql>
            delete from case_tab
            where case_definition_version_tag is null
        </sql>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <modifyDataType tableName="case_tab" columnName="tab_key" newDataType="VARCHAR(156)"/>
        <modifyDataType tableName="case_widget_tab" columnName="tab_key" newDataType="VARCHAR(156)"/>
        <modifyDataType tableName="case_widget_tab_widget" columnName="key" newDataType="VARCHAR(156)"/>
        <modifyDataType tableName="case_widget_tab_widget" columnName="tab_key" newDataType="VARCHAR(156)"/>
    </changeSet>

    <changeSet id="5" author="Ritense">
        <addPrimaryKey tableName="case_tab" columnNames="case_definition_key, case_definition_version_tag, tab_key"/>
        <addPrimaryKey tableName="case_widget_tab" columnNames="case_definition_key, case_definition_version_tag, tab_key"/>
        <addPrimaryKey tableName="case_widget_tab_widget" columnNames="case_definition_key, case_definition_version_tag, key, tab_key"/>
    </changeSet>

    <changeSet id="6" author="Ritense">
        <addForeignKeyConstraint
            baseTableName="case_widget_tab"
            baseColumnNames="case_definition_key, case_definition_version_tag, tab_key"
            constraintName="fk_case_widget_tab_case_tab"
            referencedTableName="case_tab"
            referencedColumnNames="case_definition_key, case_definition_version_tag, tab_key"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="case_widget_tab_widget"
            baseColumnNames="case_definition_key, case_definition_version_tag, tab_key"
            constraintName="fk_case_widget_tab_name_key"
            referencedTableName="case_widget_tab"
            referencedColumnNames="case_definition_key, case_definition_version_tag, tab_key"
            onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>