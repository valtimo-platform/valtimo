<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="1" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <foreignKeyConstraintExists foreignKeyTableName="task_list_column" foreignKeyName="fk_task_list_column_case_definition"/>
        </preConditions>
        <dropForeignKeyConstraint baseTableName="task_list_column"
                                  constraintName="fk_task_list_column_case_definition"/>
    </changeSet>

    <changeSet id="2" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="case_definition" columnName="case_definition_version_tag"/>
            </not>
        </preConditions>
        <dropPrimaryKey tableName="case_definition"/>
    </changeSet>

    <changeSet id="3" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="case_definition" columnName="case_definition_version_tag"/>
            </not>
        </preConditions>
        <renameColumn tableName="case_definition"
                      oldColumnName="case_definition_name"
                      newColumnName="case_definition_key"
                      columnDataType="varchar(256)"/>
        <addColumn tableName="case_definition">
            <column name="case_definition_version_tag" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="case_definition">
            <column name="case_definition_name" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="4" author="Ritense">
        <preConditions onFail="MARK_RAN">
            <not>
                <primaryKeyExists tableName="case_definition"/>
            </not>
        </preConditions>
        <addPrimaryKey tableName="case_definition" columnNames="case_definition_key, case_definition_version_tag"/>
    </changeSet>

    <changeSet id="5" author="Ritense">
        <addColumn tableName="task_list_column">
            <column name="case_definition_version_tag" type="VARCHAR(200)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>