tation\">\n\t\t\t<tr>\n\t\t\t\t<td bgcolor=\"#ffffff\">\n\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"padding: 40px; font-family: sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #686868;\">\n\t\t\t\t\t\t\t\t<!-- Please Edit Content -->\n\t\t\t\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n\t\t\t\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t\t\t\t<td align=\"left\" valign=\"top\" width=\"100\" style=\"font-weight: bold;font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\n\t\t\t\t\t\t\t\t\t\t\tOnderwerp\n\t\t\t\t\t\t\t\t\t\t</td>\n                                        <td style=\"font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\n\t\t\t\t\t\t\t\t\t\t\tBesluit Genomen\n\t\t\t\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t\t\t</table>\n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</table>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</table>\n\t\t<br>\n\t\t<!-- 1 Column : END -->\n\n\t\t<!-- 1 Column: BEGIN -->\n\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" align=\"center\" width=\"100%\" style=\"max-width: 680px;\" role=\"presentation\">\n\t\t\t<tr>\n\t\t\t\t<td bgcolor=\"#ffffff\">\n\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\n\t\t\t\t\t\t<!-- 1 Column: BEGIN -->\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td style=\"padding: 40px; font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\n\t\t\t\t\t\t\t\t<strong>Beste ${doc.aanvrager.naam},</strong>\n\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\tNa zorgvuldige overweging en overleg willen we je informeren dat er een besluit is genomen over je aanvraag voor een evenementenvergunning.\n\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\tWe hebben gekozen voor [samenvatting van het besluit] omdat [korte uitleg van de overwegingen of redenen].\n\t\t\t\t\t\t\t\t<br/><br/>\n\t\t\t\t\t\t\t\tAls je vragen hebt of aanvullende informatie nodig hebt, aarzel dan niet om contact met ons op te nemen.\n\t\t\t\t\t\t\t\t<br/><br/>\n\t\t\t\t\t\t\t\tMet vriendelijke groet,\n\t\t\t\t\t\t\t\t<br/>\n\t\t\t\t\t\t\t\tJouw gemeente\n\t\t\t\t\t\t\t\t<br/><br/>           \n\t\t\t\t\t\t\t</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</table>\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</table>\n\t\t<br>\n\n\t\t<!--[if mso]>\n\t\t</td>\n\t\t</tr>\n\t\t</table>\n\t\t<![endif]-->\n\t</div>\n</center>\n</body>\n</html>",
