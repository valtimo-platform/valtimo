\t</table>\r\n        <br/>\r\n\t\t<!-- Email Header : END -->\r\n\t\t<!-- Email Body : BEGIN -->\r\n\r\n\t\t<!-- 1 Column: BEGIN -->\r\n\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" align=\"center\" width=\"100%\" style=\"max-width: 680px;\" role=\"presentation\">\r\n\t\t\t<tr>\r\n\t\t\t\t<td bgcolor=\"#ffffff\">\r\n\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<td style=\"padding: 40px; font-family: sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #686868;\">\r\n\t\t\t\t\t\t\t\t<!-- Please Edit Content -->\r\n\t\t\t\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\r\n\t\t\t\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t\t\t\t<td align=\"left\" valign=\"top\" width=\"100\" style=\"font-weight: bold;font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\r\n\t\t\t\t\t\t\t\t\t\t\tOnderwerp\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n                                        <td style=\"font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\r\n\t\t\t\t\t\t\t\t\t\t\tOntvangstbevestiging\r\n\t\t\t\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t\t\t\t</table>\r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t</table>\r\n\t\t\t\t</td>\r\n\t\t\t</tr>\r\n\t\t</table>\r\n\t\t<br>\r\n\t\t<!-- 1 Column : END -->\r\n\r\n\t\t<!-- 1 Column: BEGIN -->\r\n\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" align=\"center\" width=\"100%\" style=\"max-width: 680px;\" role=\"presentation\">\r\n\t\t\t<tr>\r\n\t\t\t\t<td bgcolor=\"#ffffff\">\r\n\t\t\t\t\t<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" width=\"100%\">\r\n\t\t\t\t\t\t<!-- 1 Column: BEGIN -->\r\n\t\t\t\t\t\t<tr>\r\n\t\t\t\t\t\t\t<td style=\"padding: 40px; font-family: 'Open Sans', sans-serif; font-size: 14px; mso-height-rule: exactly; line-height: 1.5em; color: #555555;vertical-align: top;\">\r\n\t\t\t\t\t\t\t\t<strong>Beste ${doc.aanvrager.naam},</strong>\r\n\t\t\t\t\t\t\t\t<br/>\r\n\t\t\t\t\t\t\t\t<br/>\r\n\t\t\t\t\t\t\t\tJe aanvraag voor een evenementenvergunning is in goede orde ontvangen en geregistreerd.<br/>\r\n                                De beschikbaarheid van de aangegeven locatie wordt gecontroleerd en mits beschikbaar wordt de aanvraag inhoudelijk beoordeeld.\r\n\t\t\t\t\t\t\t\t<br/><br/>\r\n                                In het ongunstige geval dat de locatie niet beschikbaar is wordt dit direct kenbaar gemaakt via een SMS notificatie en zal om een alternatieve locatie worden gevraagd via een formulier in het portaal.<br/><br/>\r\n\t\t\t\t\t\t\t\tAls je vragen hebt of aanvullende informatie nodig hebt, aarzel dan niet om contact met ons op te nemen.\r\n\t\t\t\t\t\t\t\t<br/><br/>\r\n\t\t\t\t\t\t\t\tMet vriendelijke groet,\r\n\t\t\t\t\t\t\t\t<br/>\r\n\t\t\t\t\t\t\t\tJouw gemeente\r\n\t\t\t\t\t\t\t\t<br/><br/>           \r\n\t\t\t\t\t\t\t</td>\r\n\t\t\t\t\t\t</tr>\r\n\t\t\t\t\t</table>\r\n\t\t\t\t</td>\r\n\t\t\t</tr>\r\n\t\t</table>\r\n\t\t<br>\r\n\r\n\t\t<!--[if mso]>\r\n\t\t</td>\r\n\t\t</tr>\r\n\t\t</table>\r\n\t\t<![endif]-->\r\n\t</div>\r\n</center>\r\n</body>\r\n</html>",
