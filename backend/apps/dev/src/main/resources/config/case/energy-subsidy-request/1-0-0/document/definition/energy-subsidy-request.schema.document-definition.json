{
    "$id": "energy-subsidy-request.schema",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Energietoeslag Aanvraag",
    "type": "object",
    "properties": {
        "applicantName": {
            "type": "string",
            "description": "Naam van de aanvrager"
        },
        "householdSize": {
            "type": "integer",
            "description": "Aantal personen in het huishouden"
        },
        "applicant": {
            "type": "object",
            "description": "Aanvrager gegevens (nested properties test)",
            "properties": {
                "address": {
                    "type": "object",
                    "description": "Adresgegevens",
                    "properties": {
                        "city": {
                            "type": "string",
                            "description": "Woonplaats"
                        },
                        "postalCode": {
                            "type": "string",
                            "description": "Postcode"
                        }
                    }
                },
                "verificationStatus": {
                    "type": "string",
                    "description": "Verificatie status van building block"
                }
            }
        },
        "verifiedApplicant": {
            "type": "string",
            "description": "Geverifieerde aanvragergegevens vanuit building block"
        },
        "calculatedSubsidy": {
            "type": "integer",
            "description": "Berekend subsidiebedrag in EUR"
        },
        "eligibilityResult": {
            "type": "string",
            "description": "Resultaat van de geschiktheidsbeoordeling"
        },
        "zaakOmschrijvingFromZgw": {
            "type": "string",
            "description": "Zaak omschrijving gezet door BB1"
        },
        "zaakToelichtingBB2": {
            "type": "string",
            "description": "Zaak toelichting gezet door BB2"
        },
        "zaakEinddatumGeplandBB3": {
            "type": "string",
            "description": "Zaak einddatum gepland gezet door BB3"
        },
        "zgwActionSummary": {
            "type": "string",
            "description": "Samenvatting van alle ZGW plugin acties uitgevoerd in building blocks"
        },
        "reviewerRemarks": {
            "type": "string",
            "description": "Opmerkingen van de beoordelaar bij de subsidieberekening"
        },
        "approvalDecision": {
            "type": "string",
            "description": "Besluit van de beoordelaar (GOEDGEKEURD of AFGEKEURD)"
        }
    },
    "required": ["applicantName", "householdSize"]
}
