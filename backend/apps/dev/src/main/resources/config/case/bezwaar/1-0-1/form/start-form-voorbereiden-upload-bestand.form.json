                "values": [
                    { "label": "Nederlands", "value": "nld" }
                ]
            }
        },
        {
            "key": "pv.fileName",
            "type": "textfield",
            "input": true,
            "label": "Bestandsnaam",
            "tableView": true,
            "prefill": false,
            "validate": {
                "required": true
            },
            "defaultValue": "file.txt"
