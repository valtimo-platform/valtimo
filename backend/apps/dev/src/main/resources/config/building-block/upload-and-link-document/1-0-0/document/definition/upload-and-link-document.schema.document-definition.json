{
    "$id": "upload-and-link-document.schema",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Upload document naar documenten API en koppelen aan een zaak",
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "description": "Title of the document"
        },
        "description": {
            "type": "string",
            "description": "Description of the document"
        },
        "fileName": {
            "type": "string",
            "description": "Name of the document"
        },
        "confidentialityLevel": {
            "type": "string",
            "description": "Confidentiality Level document"
        },
        "status": {
            "type": "string",
            "description": "Status document"
        },
        "language": {
            "type": "string",
            "description": "Language document"
        },
        "temporaryDocumentId": {
            "type": "string",
            "description": "Id of temporary stored document"
        },
        "informationObjectTypeUrl": {
            "type": "string",
            "description": "Information object type url"
        }
    }
}
