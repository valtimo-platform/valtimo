
# ================================
# Monorepo AI Ignore Configuration
# Backend: Gradle/Kotlin/Java
# Frontend: Angular/Node
# ================================

# --- Version control & tooling internals ---
/.git/
/.gradle/
/.nx/

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDEs & editors ---
/.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/
.history/
.c9/
*.launch
*.sublime-workspace

# Eclipse/STSv4 specifics
.apt_generated
.factorypath
.springBeans

# NetBeans specifics
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# --- Node / Angular caches & artifacts ---
/node_modules/
/dist/
/deployment/
/out-tsc/
/tmp/
/.angular/cache/
/.sass-cache/
/npm-debug.log*
/yarn-error.log*
/pnpm-debug.log*

# --- Frontend test & profiling outputs ---
/coverage/
chrome-profiler-events.json
speed-measure-plugin.json
playwright-report/
/projects/out-tsc

# --- Documentation (generated) ---
/documentation/

# --- Backend / JVM build outputs ---
# Common Gradle/Java/Kotlin outputs
/build/
/classes/
/out/
/target/
.gradle/
.kotlin/

# Keep Gradle wrapper JAR (use explicit allow)
!gradle/wrapper/gradle-wrapper.jar

# --- Framework-specific transient DBs and outputs ---
**/h2db/**
**/derby.log

# --- Module-specific historical paths (generalized) ---
# Replaces many duplicated module entries like /contract/out, /core/out, etc.
**/out/
**/dist/
**/target/

# Private media (OpenForms etc.)
/app/openformulieren/private_media/*/

# --- Misc / temp ---
/connect.lock
/libpeerconnection.log
/testem.log
/typings/

# --- Logs (generic) ---
**/*.log

# --- Rebuilding temp files ---
.rebuilding-*

# --- Project-specific assets previously ignored ---
/projects/valtimo/layout/src/beagle/src/assets
