{
  "pluginId": "say-hello",
  "version": "0.1.0",
  "name": "Say Hello",
  "description": "POC plugin that greets a recipient using configuration and action properties",
  "provider": "Ritense",
  "compatibility": {
    "minGzacVersion": "12.0.0"
  },
  "configurationSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["greeting"],
    "properties": {
      "greeting": {
        "type": "string",
        "title": "Greeting prefix",
        "default": "Hello"
      },
      "apiKey": {
        "type": "string",
        "title": "API Key",
        "x-secret": true
      }
    },
    "additionalProperties": false
  },
  "actions": [
    {
      "key": "say-hello",
      "title": "Say Hello",
      "description": "Generates a greeting message for a recipient",
      "activityTypes": ["SERVICE_TASK_START"],
      "properties": [
        { "key": "recipient", "type": "string", "required": true }
      ]
    }
  ]
}
