{
  "name": "case-summary-plugin",
  "version": "0.1.0",
  "description": "POC external plugin — case summary using the gzacApi host function",
  "private": true,
  "scripts": {
    "installDeps": "npm install",
    "build": "valtimo-plugin-build --input src/plugin.ts --output dist/plugin.wasm",
    "pack": "valtimo-plugin-pack --wasm dist/plugin.wasm --output dist",
    "build:pack": "npm run build && npm run pack"
  },
  "devDependencies": {
    "@valtimo/plugin-sdk": "file:../../plugin-sdk",
    "esbuild": "^0.25.0",
    "@extism/js-pdk": "^1.1.0",
    "typescript": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
