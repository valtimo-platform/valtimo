{
  "name": "@valtimo/plugin-sdk",
  "version": "0.1.0",
  "description": "Valtimo External Plugin SDK for building WebAssembly plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.frontend.json",
    "installDeps": "npm install",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./frontend": {
      "types": "./dist/frontend/index.d.ts",
      "default": "./dist/frontend/index.js"
    },
    "./manifest-validation": {
      "types": "./dist/manifest-validation.d.ts",
      "default": "./dist/manifest-validation.js"
    }
  },
  "bin": {
    "valtimo-plugin-build": "./bin/valtimo-plugin-build.mjs",
    "valtimo-plugin-pack": "./bin/valtimo-plugin-pack.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "@extism/js-pdk": "^1.1.0",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@extism/js-pdk": "^1.1.0"
  },
  "license": "EUPL-1.2"
}
